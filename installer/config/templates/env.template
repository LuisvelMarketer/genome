# 🧬 Genoma Configuration Template
# Copy this file to .env and configure your settings

# === Core ===
NODE_ENV=production
GENOMA_DEV_MODE=false
GENOMA_LOG_LEVEL=info

# === Gateway ===
GENOMA_GATEWAY_TOKEN=your-secure-token-here
GENOMA_GATEWAY_PORT=18789
GENOMA_GATEWAY_BIND=lan

# === AI Provider (choose one) ===
# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google
# GEMINI_API_KEY=your-key-here

# === PGA (Evolution) ===
PGA_ENABLED=true
PGA_AUTO_MUTATION=true
PGA_AUTO_ROLLBACK=true
PGA_STORAGE_TYPE=database

# === Channels ===
# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC...

# Discord
# DISCORD_BOT_TOKEN=your-token

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
